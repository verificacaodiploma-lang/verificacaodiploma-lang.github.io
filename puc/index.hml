<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>PUC - Pontifícia Universidade de Católica</title>

<style>
body{
  margin:0;
  font-family:Arial, sans-serif;
  background:#f4f6fa;
}

.hero{
  background:linear-gradient(135deg,#00a6c7,#007fa3);
  height:260px;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-direction:column;
  color:white;
  text-align:center;
}

.hero img{
  width:90px;
  margin-bottom:10px;
}

.hero button{
  background:#1e3a8a;
  color:white;
  border:none;
  padding:14px 28px;
  border-radius:6px;
  font-weight:700;
  cursor:pointer;
}

.cards{
  display:flex;
  max-width:1100px;
  margin:-60px auto;
  gap:10px;
}

.card{
  flex:1;
  padding:30px;
  text-align:center;
  border-radius:6px;
  color:white;
  font-weight:700;
}

.yellow{background:#e6b800;color:black;}
.red{background:#d90429;}
.gray{background:#ccc;color:black;}
</style>
</head>

<body>

<header class="hero">
  <img src="logo.png">
  <h1>PUC Campinas</h1>
  <button onclick="ir()">VERIFICAÇÃO DE ALUNO</button>
</header>

<div class="cards">
  <div class="card yellow">PÓS-GRADUAÇÃO</div>
  <div class="card red">VESTIBULAR</div>
  <div class="card gray">MESTRADO</div>
</div>

<script>
function ir(){

  const overlay = document.createElement('div');
  overlay.style = `
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:white;
    display:flex;
    align-items:center;
    justify-content:center;
    flex-direction:column;
    z-index:9999;
  `;

  overlay.innerHTML = `
    <div style="
      border:4px solid #ddd;
      border-top:4px solid #1e3a8a;
      width:40px;
      height:40px;
      border-radius:50%;
      animation:spin 1s linear infinite;
    "></div>

    <p style="margin-top:12px;font-weight:600;color:#1e3a8a;">
      Redirecionando para ambiente seguro...
    </p>
  `;

  document.body.appendChild(overlay);

  setTimeout(()=>{
    window.location.href = "verificar.html";
  },1500);
}
</script>

<style>
@keyframes spin{
  to{transform:rotate(360deg);}
}
</style>

</body>
</html>
