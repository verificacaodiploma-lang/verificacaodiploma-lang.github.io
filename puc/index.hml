<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>

<title>PUC - Portal Acadêmico</title>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<style>
body{
  margin:0;
  font-family:Arial, sans-serif;
  background:#f4f6fa;
}

.hero{
  background:linear-gradient(135deg,#00a6c7,#007fa3);
  height:260px;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-direction:column;
  color:white;
  text-align:center;
}

.hero img{
  width:90px;
  margin-bottom:10px;
}

.hero button{
  background:#1e3a8a;
  color:white;
  border:none;
  padding:14px 28px;
  border-radius:6px;
  font-weight:700;
  cursor:pointer;
}

.cards{
  display:flex;
  max-width:1100px;
  margin:-60px auto;
  gap:10px;
}

.card{
  flex:1;
  padding:30px;
  text-align:center;
  border-radius:6px;
  color:white;
  font-weight:700;
}

.yellow{background:#e6b800;color:black;}
.red{background:#d90429;}
.gray{background:#ccc;color:black;}

/* modal resultado */
.modal{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:rgba(0,0,0,0.4);
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:9999;
}

.box{
  background:white;
  padding:30px;
  border-radius:10px;
  text-align:center;
  width:320px;
}

input{
  width:80%;
  padding:10px;
  margin-top:10px;
}

button.buscar{
  margin-top:10px;
  padding:10px 20px;
  background:#1e3a8a;
  color:white;
  border:none;
  cursor:pointer;
}
</style>
</head>

<body>

<header class="hero">
  <img src="logo.png">
  <h1>PUC Campinas</h1>
  <button onclick="abrirBusca()">VERIFICAÇÃO DE ALUNO</button>
</header>

<div class="cards">
  <div class="card yellow">PÓS-GRADUAÇÃO</div>
  <div class="card red">VESTIBULAR</div>
  <div class="card gray">MESTRADO</div>
</div>

<script>
const banco = window.supabase.createClient(
  "https://fghkqwxhrdodyhvfrlzz.supabase.co",
  "sb_publishable_cwIQcgCl1O0z_CKo6E8xUQ_Y-VoPyve"
);

// abre modal com input
function abrirBusca(){

  const modal = document.createElement("div");
  modal.className = "modal";

  modal.innerHTML = `
    <div class="box">
      <h3>Consultar Diploma</h3>
      <input id="registro" placeholder="Digite o registro"/>
      <br>
      <button class="buscar" onclick="buscar()">Verificar</button>
      <br><br>
      <button onclick="fechar()">Cancelar</button>
    </div>
  `;

  document.body.appendChild(modal);
}

// fecha modal
function fechar(){
  document.querySelector(".modal").remove();
}

// consulta no banco
async function buscar(){

  const reg = document.getElementById("registro").value;

  if(!reg){
    alert("Digite um registro");
    return;
  }

  document.querySelector(".box").innerHTML = "Verificando...";

  const { data, error } = await supabase
    .from("alunos")
    .select("*")
    .eq("registro", reg)
    .single();

  if(error || !data){
    document.querySelector(".box").innerHTML = `
      <p style="color:red;">Registro não encontrado</p>
      <button onclick="fechar()">Fechar</button>
    `;
    return;
  }

  document.querySelector(".box").innerHTML = `
    <h3>Verificação Confirmada</h3>
    <p><b>Nome:</b> ${data.nome}</p>
    <p><b>Curso:</b> ${data.curso}</p>
    <p><b>Conclusão:</b> ${data.conclusao}</p>
    <p style="color:green;"><b>✔ Diploma válido</b></p>
    <br>
    <button onclick="fechar()">Fechar</button>
  `;
}
</script>

</body>
</html>
